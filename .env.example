# =============================================================================
# Job Search Tool - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
# Required. Set a strong random secret for production.
FLASK_SECRET_KEY=change_this

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Optional. Path to the SQLite database file.
# Default: data/db/jobs.db
# DB_PATH=data/db/jobs.db

# -----------------------------------------------------------------------------
# Job APIs
# -----------------------------------------------------------------------------
# At least one job API should be configured for search to work.
# APIs without keys will be silently skipped.

# JSearch (via RapidAPI) - https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Remotive and We Work Remotely require no API keys (free/public APIs).

# -----------------------------------------------------------------------------
# AI / Intelligence Layer (optional)
# -----------------------------------------------------------------------------
# Without this key the app falls back to heuristic keyword matching.
ANTHROPIC_API_KEY=your_anthropic_api_key

# -----------------------------------------------------------------------------
# Email Notifications (optional)
# -----------------------------------------------------------------------------
# Required only if you want email alerts for saved searches and password resets.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
