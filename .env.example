# =============================================================================
# Nexus - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
# Required. Set a strong random secret for production.
FLASK_SECRET_KEY=change_this

# -----------------------------------------------------------------------------
# Admin Bootstrap (optional)
# -----------------------------------------------------------------------------
# Auto-create an admin account on first startup, or promote an existing user.
# Remove ADMIN_PASSWORD after first run for security.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me_immediately

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Optional. Path to the SQLite database file.
# Default: data/db/jobs.db
# DB_PATH=data/db/jobs.db

# -----------------------------------------------------------------------------
# Job APIs
# -----------------------------------------------------------------------------
# At least one job API should be configured for search to work.
# APIs without keys will be silently skipped.

# JSearch (via RapidAPI) - https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# SerpApi (Google Jobs) - https://serpapi.com/google-jobs-api
SERPAPI_KEY=your_serpapi_key_here

# USAJobs - https://developer.usajobs.gov/ (free, requires registration)
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_EMAIL=your_email@example.com

# Jooble - https://jooble.org/api/about (free tier available)
JOOBLE_API_KEY=your_jooble_api_key

# Remotive, We Work Remotely, RemoteOK, and The Muse require no API keys (free/public APIs).

# -----------------------------------------------------------------------------
# AI / Intelligence Layer (optional — pick one or neither)
# -----------------------------------------------------------------------------
# Without an AI provider the app falls back to heuristic keyword matching.

# Option 1: Claude API (cloud, paid) - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Option 2: Ollama (local, free) — install from https://ollama.com
# Run: ollama pull llama3  (or mistral, gemma2, etc.)
# OLLAMA_MODEL=llama3
# OLLAMA_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Email Notifications (optional)
# -----------------------------------------------------------------------------
# Required only if you want email alerts for saved searches and password resets.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
# If set, the /metrics endpoint requires this token via X-Metrics-Token header.
# Leave unset to allow unauthenticated access (only safe behind a reverse proxy).
# METRICS_SECRET=your_metrics_secret_here
